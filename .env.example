# ===========================================================
# DRAFTED APPAREL — Environment Variables (template)
# Copy to your Netlify site env. NEVER commit a real .env.
# ===========================================================

# ---- Generation provider ----
# 'mock' (default, free, no network) | 'openai' | 'replicate'
GENERATION_PROVIDER=mock

# OpenAI (only needed if GENERATION_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_IMAGE_COST_CENTS=4

# Replicate (only needed if GENERATION_PROVIDER=replicate)
REPLICATE_API_TOKEN=
REPLICATE_MODEL=black-forest-labs/flux-schnell
REPLICATE_IMAGE_COST_CENTS=3

# ---- Supabase (added in later steps) ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (added in step 3) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Email (added later) ----
# e.g. Resend / Postmark for order + proof + manual-touch notifications
EMAIL_API_KEY=
OWNER_NOTIFICATION_EMAIL=

# ---- Site ----
SITE_URL=https://draftedapparel.com
